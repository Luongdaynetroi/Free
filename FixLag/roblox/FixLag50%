--[[
FixLag Super VIP - FULL CODE-ONLY (Enhanced)
Author: Generated for Lương
Description:
  - Client-side visual optimizer. Safe-only: no exploit APIs, no destructive deletes, no interference with other players' characters/tools.
  - Keeps player's UI and enemy NPCs intact even at ultra intensity (150%).
  - Auto-reapply on spawn, best-effort Undo, and preservation whitelist for important game elements (PlayerGui, CoreGui, Humanoid models, named enemy folders).
  - Very long file with extended comments and padding to meet user requirement for size.

Usage:
  - Paste into a LocalScript under StarterPlayerScripts or PlayerGui.
  - Edit CONFIG section at top: set PRESET_NAME or MODE_PERCENT (20/50/75/100/150).
  - Script auto-applies on load and periodically re-applies to new instances.

Safety:
  - No calls to setfpscap, sethiddenproperty, getnilinstances.
  - Does not Destroy other players' assets or remove islands.
  - Undo attempts to restore saved properties where possible.

Notes on "preserving NPCs":
  - This script treats any Instance that is descendant of a Model with a Humanoid (excluding the local player's character) as a protected NPC group.
  - Any visual changes (decals, textures, mesh changes) will skip instances that are under protected NPCs to avoid breaking gameplay visuals for enemies.

]]

-- ===================== CONFIG (edit here) =====================
local PRESET_NAME = High            -- e.g. "Low","High","VeryHigh","SuperHigh","FixAll","Ultra"
local MODE_PERCENT = 50          -- valid: 20, 50, 75, 100, 150 (if PRESET_NAME set, it takes precedence)

local AUTO_REAPPLY_ON_DESCENDANT_ADDED = true
local AUTO_SCAN_INTERVAL = 10      -- seconds, 0 to disable
local ENABLE_UNDO = true
local ENABLE_LOG = false

-- Whitelist names/folders to always protect (game-specific)
local WHITELIST_FOLDERS = {"Enemies", "NPCs", "Monsters", "Bosses"}

-- ===================== SERVICES & LOCALS =====================
local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")
local UserInputService = game:GetService("UserInputService")
local HttpService = game:GetService("HttpService")

local MaterialService = game:GetService("MaterialService")

local ME = Players.LocalPlayer
local LOCAL_NAME = ME and ME.Name or "LocalPlayer"

-- ===================== LOG / HELPERS =====================
local function log(...)
    if ENABLE_LOG then warn("[FixLag]", ... ) end
end

local function notify(txt)
    pcall(function()
        StarterGui:SetCore("SendNotification", {Title = "FixLag", Text = tostring(txt), Duration = 3})
    end)
end

local function safeGet(inst, prop)
    local ok, val = pcall(function() return inst[prop] end)
    if ok then return val end
    return nil
end
local function safeSet(inst, prop, val)
    pcall(function() inst[prop] = val end)
end

local function clamp(n, lo, hi)
    if n < lo then return lo end
    if n > hi then return hi end
    return n
end

-- ===================== PRESETS =====================
local PRESETS = {
    Low = {Intensity = 20,  Desc = "Conservative"},
    High = {Intensity = 50, Desc = "Balanced"},
    VeryHigh = {Intensity = 75, Desc = "Aggressive"},
    SuperHigh = {Intensity = 100, Desc = "Maximum safe"},
    FixAll = {Intensity = 100, Desc = "Alias for SuperHigh"},
    Ultra = {Intensity = 150, Desc = "Extra aggressive (150%)"}
}

-- ===================== STATE =====================
local STATE = {
    applied = false,
    lastIntensity = nil,
    saved = {}, -- inst -> { prop = value }
    savedWeak = setmetatable({}, { __mode = "k" }),
    scanning = false
}

-- Save prop for undo
local function saveProp(inst, prop)
    if not ENABLE_UNDO then return end
    if not inst or not prop then return end
    local tab = STATE.saved[inst]
    if not tab then
        tab = {} STATE.saved[inst] = tab STATE.savedWeak[inst] = true
    end
    if tab[prop] == nil then
        local ok, val = pcall(function() return inst[prop] end)
        if ok then tab[prop] = val end
    end
end

local function undoAll()
    local restoredCount = 0
    for inst, props in pairs(STATE.saved) do
        if inst and props then
            for prop, val in pairs(props) do
                pcall(function() inst[prop] = val end)
            end
            restoredCount = restoredCount + 1
        end
    end
    STATE.saved = {}
    STATE.savedWeak = setmetatable({}, { __mode = "k" })
    STATE.applied = false
    notify("Undo (best-effort) restored " .. tostring(restoredCount) .. " instances")
    log("Undo restored", restoredCount)
end

-- ===================== PROTECTED CHECKS =====================
-- Any instance under these categories should NOT be touched even in Ultra mode
local function isDescendantOfPlayerGui(inst)
    if not inst then return false end
    if ME and ME:FindFirstChild("PlayerGui") and inst:IsDescendantOf(ME.PlayerGui) then return true end
    -- also skip CoreGui
    if inst:IsDescendantOf(game:GetService("CoreGui")) then return true end
    return false
end

-- Find ancestor model with Humanoid (excluding local player's character)
local function findHumanoidAncestor(inst)
    local current = inst
    while current and current ~= game do
        if current:IsA("Model") then
            local humanoid = current:FindFirstChildWhichIsA("Humanoid")
            if humanoid then return current, humanoid end
        end
        current = current.Parent
    end
    return nil, nil
end

local function isProtectedNPC(inst)
    if not inst then return false end
    -- Protect anything under player's character
    if inst:IsDescendantOf(ME.Character) then return true end
    -- Protect GUIs tied to player's PlayerGui
    if isDescendantOfPlayerGui(inst) then return true end
    -- If instance belongs to any Model that has a Humanoid (and is not the local player's character), treat it as NPC and protect
    local mdl, hum = findHumanoidAncestor(inst)
    if mdl and hum and mdl ~= ME.Character then
        return true
    end
    -- If instance is descendant of folders with names in whitelist, protect
    local parent = inst
    while parent and parent ~= game do
        if parent:IsA("Folder") or parent:IsA("Model") or parent:IsA("ModuleScript") or parent:IsA("Folder") then
            for _, name in ipairs(WHITELIST_FOLDERS) do
                if parent.Name == name then return true end
            end
        end
        parent = parent.Parent
    end
    return false
end

-- ===================== INTENSITY MAPPING =====================
local function buildSettingsFromIntensity(intensity)
    intensity = math.max(0, intensity)
    if intensity > 150 then intensity = 150 end

    local qualityLevel = math.floor(10 - (intensity / 15))
    if qualityLevel < 1 then qualityLevel = 1 end
    if qualityLevel > 10 then qualityLevel = 10 end

    local postEffects = intensity < 30
    local shadows = intensity < 20
    local particles = intensity < 25

    local decalTransparency
    if intensity >= 150 then decalTransparency = 0.95
    elseif intensity >= 120 then decalTransparency = 0.9
    elseif intensity >= 100 then decalTransparency = 0.85
    elseif intensity >= 75 then decalTransparency = 0.7
    elseif intensity >= 50 then decalTransparency = 0.5
    elseif intensity >= 20 then decalTransparency = 0.3
    else decalTransparency = 0 end

    local meshRenderFidelity = 4
    if intensity >= 75 then meshRenderFidelity = 2 elseif intensity >= 50 then meshRenderFidelity = 3 end

    local aggressive = (intensity >= 100)
    local hideLocalGuis = (intensity >= 150)
    local simplifyWater = intensity >= 20

    return {
        Intensity = intensity,
        QualityLevel = qualityLevel,
        PostEffects = postEffects,
        Shadows = shadows,
        Particles = particles,
        DecalTransparency = decalTransparency,
        MeshRenderFidelity = meshRenderFidelity,
        Aggressive = aggressive,
        HideLocalGuis = hideLocalGuis,
        SimplifyWater = simplifyWater
    }
end

-- ===================== APPLY FUNCTIONS =====================
local function applyLightingSettings(s)
    pcall(function()
        saveProp(Lighting, "GlobalShadows")
        saveProp(Lighting, "ShadowSoftness")
        saveProp(Lighting, "FogEnd")

        if s.Shadows == false then
            safeSet(Lighting, "GlobalShadows", false)
            safeSet(Lighting, "ShadowSoftness", 0)
            safeSet(Lighting, "FogEnd", 9e9)
        else
            safeSet(Lighting, "GlobalShadows", true)
        end

        for _, ef in pairs(Lighting:GetChildren()) do
            if ef:IsA("PostEffect") or ef:IsA("BloomEffect") or ef:IsA("DepthOfFieldEffect") or ef:IsA("ColorCorrectionEffect") or ef:IsA("BlurEffect") then
                saveProp(ef, "Enabled")
                safeSet(ef, "Enabled", s.PostEffects)
            end
        end
    end)
end

local function applyTerrainSettings(s)
    pcall(function()
        local terrain = workspace:FindFirstChildOfClass("Terrain")
        if terrain then
            saveProp(terrain, "WaterWaveSize")
            saveProp(terrain, "WaterWaveSpeed")
            saveProp(terrain, "WaterReflectance")
            saveProp(terrain, "WaterTransparency")
            if s.SimplifyWater then
                safeSet(terrain, "WaterWaveSize", 0)
                safeSet(terrain, "WaterWaveSpeed", 0)
                safeSet(terrain, "WaterReflectance", 0)
                safeSet(terrain, "WaterTransparency", 0)
            end
        end
    end)
end

local function applyParticlesSettings(s)
    pcall(function()
        for _, inst in pairs(game:GetDescendants()) do
            local cls = inst.ClassName
            if cls == "ParticleEmitter" or cls == "Trail" or cls == "Smoke" or cls == "Fire" or cls == "Sparkles" then
                if not inst:IsDescendantOf(ME.Character) and not inst:FindFirstAncestorWhichIsA("BackpackItem") and not isProtectedNPC(inst) then
                    saveProp(inst, "Enabled")
                    safeSet(inst, "Enabled", s.Particles)
                end
            end
        end
    end)
end

local function applyDecalsSettings(s)
    pcall(function()
        for _, inst in pairs(game:GetDescendants()) do
            if inst:IsA("Decal") or inst:IsA("Texture") then
                if not inst:IsDescendantOf(ME.Character) and not inst:FindFirstAncestorWhichIsA("BackpackItem") and not isProtectedNPC(inst) and not isDescendantOfPlayerGui(inst) then
                    saveProp(inst, "Transparency")
                    safeSet(inst, "Transparency", s.DecalTransparency)
                end
            elseif inst:IsA("FaceInstance") then
                if not inst:IsDescendantOf(ME.Character) and not inst:FindFirstAncestorWhichIsA("BackpackItem") and not isProtectedNPC(inst) and not isDescendantOfPlayerGui(inst) then
                    local ok = pcall(function() return inst.Transparency end)
                    if ok then
                        saveProp(inst, "Transparency")
                        safeSet(inst, "Transparency", s.DecalTransparency)
                    end
                end
            end
        end
    end)
end

local function applyMeshSettings(s)
    pcall(function()
        for _, inst in pairs(game:GetDescendants()) do
            if inst:IsA("MeshPart") then
                if not inst:IsDescendantOf(ME.Character) and not isProtectedNPC(inst) then
                    saveProp(inst, "RenderFidelity")
                    saveProp(inst, "Reflectance")
                    saveProp(inst, "Material")
                    safeSet(inst, "RenderFidelity", s.MeshRenderFidelity)
                    safeSet(inst, "Reflectance", 0)
                    pcall(function() inst.Material = Enum.Material.Plastic end)
                end
            elseif inst:IsA("SpecialMesh") or inst:IsA("FileMesh") then
                if not inst:IsDescendantOf(ME.Character) and not isProtectedNPC(inst) then
                    local ok = pcall(function() return inst.TextureId end)
                    if ok then saveProp(inst, "TextureId") end
                    if s.Aggressive then pcall(function() inst.TextureId = "" end) end
                end
            end
        end
    end)
end

local function applyLocalGuiHiding(s)
    if not s.HideLocalGuis then return end
    pcall(function()
        for _, inst in pairs(game:GetDescendants()) do
            -- Only touch GUIs that are not player's PlayerGui, not CoreGui, and not part of protected NPCs
            if (inst:IsA("BillboardGui") or inst:IsA("SurfaceGui") or inst:IsA("ScreenGui") or inst:IsA("TextLabel") or inst:IsA("ImageLabel") or inst:IsA("GuiObject")) then
                if not inst:IsDescendantOf(ME.PlayerGui) and not inst:IsDescendantOf(ME.Character) and not isProtectedNPC(inst) and not inst:IsDescendantOf(game:GetService("CoreGui")) then
                    -- Some GUIs are crucial for gameplay (attached to NPCs) - we skip those via isProtectedNPC
                    -- Save Enabled/Visible where possible
                    local okV = pcall(function() return inst.Visible end)
                    if okV then saveProp(inst, "Visible") pcall(function() inst.Visible = false end) end
                    local okE = pcall(function() return inst.Enabled end)
                    if okE then saveProp(inst, "Enabled") pcall(function() inst.Enabled = false end) end
                end
            end
        end
    end)
end

local function applyExtraClientTweaks()
    pcall(function()
        if pcall(function() return settings().Rendering end) then
            pcall(function() settings().Rendering.MeshPartDetailLevel = Enum.MeshPartDetailLevel.Level04 end)
            -- avoid exploit-only APIs
        end

        pcall(function()
            for _, v in pairs(MaterialService:GetChildren()) do
                if typeof(v) == "Instance" then
                    -- We don't destroy materials (destructive). Instead attempt to disable 2022 materials flag.
                end
            end
            pcall(function() MaterialService.Use2022Materials = false end)
        end)
    end)
end

-- ===================== APPLYER WRAPPER =====================
local function applyIntensity(intensity)
    intensity = clamp(intensity, 0, 150)
    local s = buildSettingsFromIntensity(intensity)
    log("Applying intensity:", intensity)

    applyLightingSettings(s)
    applyTerrainSettings(s)
    applyParticlesSettings(s)
    applyDecalsSettings(s)
    applyMeshSettings(s)
    applyExtraClientTweaks()
    applyLocalGuiHiding(s)

    STATE.applied = true
    STATE.lastIntensity = intensity
    notify("FixLag applied: " .. tostring(intensity) .. "%")
end

-- ===================== DESCENDANT HANDLER =====================
local function handleNewDescendant(desc)
    if not AUTO_REAPPLY_ON_DESCENDANT_ADDED then return end
    task.defer(function()
        local intensity = STATE.lastIntensity or (PRESET_NAME and PRESETS[PRESET_NAME] and PRESETS[PRESET_NAME].Intensity) or MODE_PERCENT or 75
        local s = buildSettingsFromIntensity(intensity)
        -- Apply targeted changes only for the new descendant
        pcall(function()
            if desc:IsA("Decal") or desc:IsA("Texture") then
                if not desc:IsDescendantOf(ME.Character) and not desc:FindFirstAncestorWhichIsA("BackpackItem") and not isProtectedNPC(desc) and not isDescendantOfPlayerGui(desc) then
                    saveProp(desc, "Transparency")
                    safeSet(desc, "Transparency", s.DecalTransparency)
                end
            elseif desc.ClassName == "ParticleEmitter" or desc.ClassName == "Smoke" or desc.ClassName == "Fire" or desc.ClassName == "Trail" or desc.ClassName == "Sparkles" then
                if not desc:IsDescendantOf(ME.Character) and not desc:FindFirstAncestorWhichIsA("BackpackItem") and not isProtectedNPC(desc) then
                    saveProp(desc, "Enabled")
                    safeSet(desc, "Enabled", s.Particles)
                end
            elseif desc:IsA("MeshPart") then
                if not desc:IsDescendantOf(ME.Character) and not isProtectedNPC(desc) then
                    saveProp(desc, "RenderFidelity")
                    saveProp(desc, "Material")
                    safeSet(desc, "RenderFidelity", s.MeshRenderFidelity)
                    pcall(function() desc.Material = Enum.Material.Plastic end)
                end
            elseif desc:IsA("SpecialMesh") or desc:IsA("FileMesh") then
                if not desc:IsDescendantOf(ME.Character) and not isProtectedNPC(desc) then
                    local ok = pcall(function() return desc.TextureId end)
                    if ok then saveProp(desc, "TextureId") end
                    if s.Aggressive then pcall(function() desc.TextureId = "" end) end
                end
            elseif desc:IsA("PostEffect") then
                saveProp(desc, "Enabled")
                safeSet(desc, "Enabled", s.PostEffects)
            elseif desc:IsA("BillboardGui") or desc:IsA("SurfaceGui") then
                if not desc:IsDescendantOf(ME.PlayerGui) and not isProtectedNPC(desc) then
                    local okV = pcall(function() return desc.Enabled end)
                    if okV then saveProp(desc, "Enabled") safeSet(desc, "Enabled", false) end
                end
            end
        end)
    end)
end

-- ===================== PERIODIC SCANNER =====================
local function periodicScanner()
    if AUTO_SCAN_INTERVAL <= 0 then return end
    while true do
        task.wait(AUTO_SCAN_INTERVAL)
        if not STATE.applied then continue end
        log("Periodic scan: re-applying intensity", STATE.lastIntensity)
        applyIntensity(STATE.lastIntensity or (PRESET_NAME and PRESETS[PRESET_NAME] and PRESETS[PRESET_NAME].Intensity) or MODE_PERCENT or 75)
    end
end

-- ===================== DETERMINE & START =====================
local function determineIntensity()
    if PRESET_NAME and PRESETS[PRESET_NAME] then
        return PRESETS[PRESET_NAME].Intensity
    end
    if MODE_PERCENT and type(MODE_PERCENT) == "number" then
        return MODE_PERCENT
    end
    return 75
end

-- Connect DescendantAdded
if AUTO_REAPPLY_ON_DESCENDANT_ADDED then
    game.DescendantAdded:Connect(handleNewDescendant)
end

-- Start periodic scanner
if AUTO_SCAN_INTERVAL and AUTO_SCAN_INTERVAL > 0 then
    task.spawn(periodicScanner)
end

-- Initial apply
local ok, err = pcall(function() applyIntensity(determineIntensity()) end)
if not ok then
    warn("FixLag: initial apply failed: ", tostring(err))
end

-- Expose safe APIs
_G.FixLag_ApplyIntensity = applyIntensity
_G.FixLag_Undo = undoAll
_G.FixLag_ScanReport = function()
    local counts = {Decals=0, Particles=0, MeshParts=0, SpecialMeshes=0, PostEffects=0, GuiObjects=0}
    for _, inst in pairs(game:GetDescendants()) do
        if inst:IsA("Decal") or inst:IsA("Texture") then counts.Decals = counts.Decals + 1 end
        if inst.ClassName == "ParticleEmitter" or inst.ClassName == "Trail" or inst.ClassName == "Smoke" or inst.ClassName == "Sparkles" or inst.ClassName == "Fire" then counts.Particles = counts.Particles + 1 end
        if inst:IsA("MeshPart") then counts.MeshParts = counts.MeshParts + 1 end
        if inst:IsA("SpecialMesh") or inst:IsA("FileMesh") then counts.SpecialMeshes = counts.SpecialMeshes + 1 end
        if inst:IsA("PostEffect") then counts.PostEffects = counts.PostEffects + 1 end
        if inst:IsA("GuiObject") then counts.GuiObjects = counts.GuiObjects + 1 end
    end
    return counts
end

